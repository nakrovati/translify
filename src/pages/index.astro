---
import MdiGoogleTranslate from "@assets/icons/MdiGoogleTranslate.astro";
import PhClipboardText from "@assets/icons/PhClipboardText.astro";
import PhCopy from "@assets/icons/PhCopy.astro";

import Layout from "../layouts/Layout.astro";
---

<Layout
  description="Convert Georgian transliteration to back the Gerogian"
  title="Translify: Georgian Transliteration Converter"
>
  <div class="mx-auto flex flex-col gap-8">
    <section class="flex flex-col gap-2">
      <div>
        <label class="text-sm" for="source-text">Source text</label>
        <textarea
          aria-describedby="char-count"
          class="textarea w-full"
          id="source-text"
          name="source-text"
          placeholder="Type Gerogian transliterated (Latin) text here"
          rows="5"></textarea>
      </div>

      <div class="flex justify-between gap-2">
        <div aria-live="polite" id="char-count">0</div>

        <button
          aria-label="Paste text"
          class="btn btn-square"
          id="paste-btn"
          type="button"
        >
          <PhClipboardText aria-hidden="true" class="size-6" />
        </button>
      </div>

      <button
        aria-controls="result-text"
        class="btn btn-primary mx-auto w-full max-w-48"
        id="transliterate-btn"
        type="button"
      >
        Convert
      </button>
    </section>

    <section class="flex flex-col gap-2">
      <div>
        <label class="text-sm" for="result-text">Result text:</label>
        <textarea
          aria-live="polite"
          class="textarea w-full"
          id="result-text"
          lang="ka-GE"
          name="result-text"
          placeholder="Result text"
          rows="5"></textarea>
      </div>

      <div aria-label="result-actions" class="ml-auto" role="group">
        <details class="dropdown dropdown-end">
          <summary class="btn m-1" id="translate-dropdown-btn">
            Translate with
          </summary>
          <ul
            class="menu dropdown-content bg-base-100 rounded-box z-1 w-52 p-2 shadow-sm"
          >
            <li>
              <a id="gt-link" rel="noopener noreferrer" target="_blank">
                <MdiGoogleTranslate
                  aria-hidden="true"
                  height="2em"
                  width="2em"
                />Google Translate
              </a>
            </li>
          </ul>
        </details>

        <button
          aria-label="Copy result"
          class="btn btn-square ml-auto"
          id="copy-btn"
          type="button"
        >
          <PhCopy aria-hidden="true" class="size-6" />
        </button>
      </div>
    </section>
  </div>
</Layout>

<script>
  import { transliterate } from "../helpers/transliterate";

  const sourceTextarea = document.querySelector(
    "#source-text",
  ) as HTMLTextAreaElement;
  const resultTextarea = document.querySelector(
    "#result-text",
  ) as HTMLTextAreaElement;

  const charCountElement = document.querySelector(
    "#char-count",
  ) as HTMLDivElement;
  const transliterateButton = document.querySelector(
    "#transliterate-btn",
  ) as HTMLButtonElement;
  const copyBtn = document.querySelector("#copy-btn") as HTMLButtonElement;
  const pasteBtn = document.querySelector("#paste-btn") as HTMLButtonElement;
  const translateDropdownBtn = document.querySelector(
    "#translate-dropdown-btn",
  ) as HTMLButtonElement;

  const originalCopyBtnHTML = copyBtn.innerHTML;

  const gtLink = document.querySelector("#gt-link") as HTMLAnchorElement;
  gtLink.addEventListener("pointerdown", () => {
    gtLink.href = `https://translate.google.com/?sl=ka&tl=en&text=${encodeURIComponent(
      resultTextarea.value,
    )}`;
  });

  function updateCopyState() {
    const isDisabled = !resultTextarea.value.trim();
    copyBtn.toggleAttribute("disabled", isDisabled);
    copyBtn.classList.toggle("btn-disabled", isDisabled);
  }

  function updateTranslateState() {
    const isDisabled = !resultTextarea.value.trim();
    translateDropdownBtn.toggleAttribute("disabled", isDisabled);
    translateDropdownBtn.classList.toggle("btn-disabled", isDisabled);
  }

  sourceTextarea.addEventListener("input", (event) => {
    const target = event.target as HTMLTextAreaElement;
    charCountElement.textContent = String(target.value.length);
  });

  resultTextarea.addEventListener("input", updateTranslateState);
  resultTextarea.addEventListener("input", updateCopyState);

  transliterateButton.addEventListener("click", () => {
    const text = sourceTextarea.value;
    resultTextarea.value = transliterate(text);

    updateTranslateState();
    updateCopyState();
  });

  copyBtn.addEventListener("click", async () => {
    const copyText = resultTextarea.value;
    if (!copyText.trim()) return;

    await navigator.clipboard.writeText(copyText);

    copyBtn.textContent = "Copied";
    copyBtn.classList.add("btn-success");
    copyBtn.classList.remove("btn-square");

    setTimeout(() => {
      copyBtn.innerHTML = originalCopyBtnHTML;
      copyBtn.classList.remove("btn-success");
      copyBtn.classList.add("btn-square");
    }, 1000);
  });

  pasteBtn.addEventListener("click", async () => {
    try {
      const text = await navigator.clipboard.readText();

      sourceTextarea.value = text;

      sourceTextarea.dispatchEvent(new Event("input", { bubbles: true }));
    } catch (error) {
      console.error(error);
    }
  });

  updateTranslateState();
  updateCopyState();
</script>
